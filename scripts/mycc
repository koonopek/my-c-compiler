#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

compiler_args=()
for arg in "$@"; do
  case "$arg" in
    --lex|--parse)
      # Test-suite stage flags are handled by the adapter for now.
      ;;
    *)
      compiler_args+=("$arg")
      ;;
  esac
done

cargo build --quiet --manifest-path "$repo_root/Cargo.toml"
exec "$repo_root/target/debug/my-c-compiler" "${compiler_args[@]}"
